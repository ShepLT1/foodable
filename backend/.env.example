# Backend environment variables (FastAPI)
# Instructions: Copy to an .env file and fill in values

# Supabase - start supabase locally with `supabase start` to get these values for your local dev:
SUPABASE_URL=http://127.0.0.1:54321 # API URL (JWTs are verified via this URL's JWKS endpoint)
SUPABASE_SECRET_KEY= # server-side secret key (sb_secret_...)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@127.0.0.1:54322/postgres # only if connecting to Postgres directly
FRONTEND_URL=http://localhost:5173 # local url shown when starting frontend app via 'npm run dev'
ANTHROPIC_API_KEY= # Anthropic API key for AI reciepe generation, get one from console.anthropic.com)
